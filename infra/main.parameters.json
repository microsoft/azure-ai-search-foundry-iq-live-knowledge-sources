{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "nameSalt": {
      "value": "${AZURE_NAME_SALT}"
    },
    "staticWebAppLocation": {
      "value": "${AZURE_STATIC_WEB_APP_LOCATION}"
    },
    "hostingMode": {
      "value": "${AZURE_HOSTING_MODE}"
    },
    "appServiceSku": {
      "value": "${AZURE_APP_SERVICE_SKU}"
    },
    "deploymentMode": {
      "value": "${DEPLOYMENT_MODE}"
    },
    "fabricCapacityMode": {
      "value": "${FABRIC_CAPACITY_MODE}"
    },
    "fabricLocation": {
      "value": "${FABRIC_LOCATION}"
    },
    "fabricCapacityName": {
      "value": "${FABRIC_CAPACITY_NAME}"
    },
    "fabricCapacitySku": {
      "value": "${FABRIC_CAPACITY_SKU}"
    },
    "fabricCapacityAdmin": {
      "value": "${FABRIC_CAPACITY_ADMIN}"
    }
  }
}
