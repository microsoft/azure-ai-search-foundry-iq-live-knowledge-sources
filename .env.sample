# Deployment mode
# Choose one:
# - byo-fabric: create Azure/Search/MCP/app resources and connect an existing Fabric ontology.
# - mcp-only: create Azure/Search/MCP/app resources and skip Fabric.
# - full: create Azure/Search/MCP/app resources plus Fabric capacity/workspace/lakehouse/ontology.
DEPLOYMENT_MODE=byo-fabric

# Azure AI Search
SEARCH_ENDPOINT=https://<search-service>.search.windows.net
SEARCH_API_VERSION=2026-05-01-preview
SEARCH_API_KEY=<search-admin-or-query-key-for-poc>

# Knowledge base
KNOWLEDGE_BASE_NAME=live-knowledge-sources-kb
MCP_ONLY_KNOWLEDGE_BASE_NAME=live-knowledge-sources-mcp-kb
AZURE_OPENAI_ENDPOINT=https://<azure-openai-or-foundry-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_ID=<chat-completions-deployment-name>
AZURE_OPENAI_MODEL_NAME=<model-name>
# Optional. If omitted in the azd deployment, Search uses managed identity RBAC.
AZURE_OPENAI_API_KEY=<optional-azure-openai-api-key-for-local-rest-testing>

# MCP Server Knowledge Source
MCP_KNOWLEDGE_SOURCE_NAME=microsoft-learn-mcp-ks
MCP_SERVER_URL=https://learn.microsoft.com/api/mcp
MCP_TOOL_NAME=microsoft_docs_search

# Fabric Ontology Knowledge Source
FABRIC_ONTOLOGY_KNOWLEDGE_SOURCE_NAME=fabric-ontology-ks

# Required when DEPLOYMENT_MODE=byo-fabric.
# Optional in DEPLOYMENT_MODE=full when you want to connect existing Fabric assets instead of creating new ones.
# Ignored when DEPLOYMENT_MODE=mcp-only.
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
FABRIC_ONTOLOGY_ID=00000000-0000-0000-0000-000000000001
FABRIC_USER_SEARCH_TOKEN=<raw-user-token-for-https://search.azure.com/.default>

# Fabric greenfield automation. Use a region where the subscription has Fabric quota.
# The tested external tenant uses westus3 for F2 capacity.
FABRIC_CAPACITY_MODE=create
FABRIC_CAPACITY_SKU=F2
FABRIC_CAPACITY_NAME=<optional-fabric-capacity-name>
FABRIC_CAPACITY_ADMIN=<admin-upn-for-created-capacity>
FABRIC_LOCATION=westus3
FABRIC_WORKSPACE_NAME=<optional-fabric-workspace-name>
FABRIC_LAKEHOUSE_NAME=airline_ops_lakehouse
FABRIC_ONTOLOGY_NAME=AirlineOpsOntology

# External tenant login helper
# Copy to .env.external.local and fill locally. Do not commit tenant-specific values.
EXTERNAL_TENANT_ID=00000000-0000-0000-0000-000000000000
EXTERNAL_AZURE_CONFIG_DIR=~/.azure-foundry-iq-ext
# Optional safety rails for live E2E runs. Leave blank for generic sample usage.
E2E_EXPECTED_SUBSCRIPTION_NAME=
E2E_EXPECTED_TENANT_ID=

# Search-backed semantic join extension
AIRLINE_OPS_INDEX_NAME=airline-ops-regulatory-docs

# Demo app runtime
DEPLOYMENT_SUMMARY_PATH=deployments/dev/deployment-summary.md
NEXT_TELEMETRY_DISABLED=1

# Notebook/runtime safety
RUN_LIVE_CALLS=false
